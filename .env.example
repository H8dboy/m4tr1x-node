# M4TR1X — Environment Configuration
# Copy this file to .env and fill in your values.
# The app works without any of these — all have safe defaults.

# Optional API key to protect the local API server.
# Leave empty to allow all requests from the Electron app (recommended).
M4TR1X_API_KEY=

# Maximum upload file size in megabytes (default: 100)
MAX_FILE_SIZE_MB=100

# Comma-separated list of allowed CORS origins (default: http://localhost:8080)
# You normally don't need to change this.
ALLOWED_ORIGINS=http://localhost:8080

# Private M4TR1X node URL — shop and crypto calls route exclusively here.
# Set this to your private server to prevent third-party interception of payments.
# Leave empty to use localhost fallback (dev only).
PRIVATE_NODE_URL=https://node.m4tr1x.app

# H8 Token economy — addresses founder/platform/server
H8_MINT_ADDRESS=H800000000000000000000000000000000000000
H8_PLATFORM_ADDRESS=H811111111111111111111111111111111111111
H8_SERVER_ADDRESS=H822222222222222222222222222222222222222

# Head node URL — ledger canonical endpoint (set when head node is deployed)
HEAD_NODE_URL=

# Crowdtrain — minimum votes to confirm a label (default: 3, raise to 10+ at scale)
CROWDTRAIN_MIN_VOTES=3
